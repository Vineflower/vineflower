package pkg;

import java.util.ArrayList;
import java.util.List;

public class TestWhileLoopPromotion {
   public void test() {
      int i = 0;// 8
      List<Integer> list = new ArrayList();// 9

      while (i < 10) {// 10
         list.add(i);// 11
         i++;// 12
      }
   }// 14
}

