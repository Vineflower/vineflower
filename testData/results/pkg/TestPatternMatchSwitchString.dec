package pkg;

public class TestPatternMatchSwitchString {
   private String field;

   public void test(String s) {
      switch (s) {// 7
         case "a":
         case "b":
         case "c":
         case "d":
            this.field = s;// 8
            return;
         case null:
         default:
            throw new RuntimeException("illegal");// 9
      }
   }

   public void test1(String s) {
      switch (s) {// 14
         case "a":
         case "b":
            this.field = s + "a";// 15
            break;
         case "c":
         case "d":
            this.field = s + "b";// 16
            break;
         case null:
         default:
            throw new RuntimeException("illegal");// 17
      }
   }// 19
}

