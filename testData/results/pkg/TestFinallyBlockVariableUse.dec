      } finally {
         int id = i - j;// 18
         if (id > 0) {// 19
            this.accept(new Object[]{id, s, i, j});// 21
         }
      }
   }

   private boolean condition(int i) {
      return i-- > 0;// 27
   }

   private void accept(Object[] args) {
   }// 32
}

