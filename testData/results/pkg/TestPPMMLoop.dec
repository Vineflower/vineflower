package pkg;

public class TestPPMMLoop {
   public void test(int a, String s) {
      while (++a > 0) {// 5
         s = s + "a";// 6
      }
   }// 8

   public void test1(int a, String s) {
      while (a++ > 0) {// 11
         s = s + "a";// 12
      }
   }// 14

   public void test2(int a, String s) {
      while (--a > 0) {// 17
         s = s + "a";// 18
      }
   }// 20

   public void test3(int a, String s) {
      while (a-- > 0) {// 23
         s = s + "a";// 24
      }
   }// 26

   public void test4() {
      int vvv1 = -68;// 29
      int var10000 = ++vvv1;// 30
