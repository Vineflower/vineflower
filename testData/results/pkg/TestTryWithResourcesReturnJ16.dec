   public String testComplex(File f, File f2, File f3) throws FileNotFoundException {
      try (
         Scanner scanner = this.create(f);// 100
         Scanner s2 = this.create(f2);// 101
      ) {
         scanner.next();// 102
         if (!scanner.hasNext() || !s2.hasNext()) {// 104
            return null;// 105
         }

         try (Scanner s = this.create(f3)) {// 108
            scanner.next();// 109

            for (int i = 0; i < s.nextInt(); i++) {// 111
               System.out.println(i);// 112
            }

            return s.next();// 115 119
         }
      }
   }

