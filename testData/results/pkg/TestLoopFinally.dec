public class TestLoopFinally {
   public void test() {
      for (int i = 0; i < 10; i++) {// 7 18
         try {
            System.out.println(i);// 9
         } finally {
            System.out.println("finally");// 11
            if (i == 5) {// 13
               break;
            }

            System.out.println("finally2");// 17
         }
      }

      System.out.println("after");// 21
   }// 22

   public void test1() {
      for (int i = 0; i < 10; i++) {// 25
         try {
            System.out.println(i);// 27
         } finally {
            System.out.println("finally");// 29
            if (i != 5) {// 31
               if (i == 4) {// 34
                  System.out.println("break");// 35
                  break;// 36
               }

               System.out.println("finally2");// 39
            }

            System.out.println("continue");// 32
            continue;// 33
         }
      }

      System.out.println("after");// 43
   }// 44

   public void test2() {
      for (int i = 0; i < 10; i++) {// 47
         try {
            System.out.println(i);// 49
         } finally {
            System.out.println("finally");// 51
            if (i != 5) {// 53
               continue;
            }
            break;
         }
      }

      System.out.println("after");// 61
   }// 62

   public int test3(int x) {
      do {
         try {
            if (x == 1) {// 68
               return 1;// 69
            }

            System.out.println("Oops");// 72
