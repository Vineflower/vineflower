public class TestLoopFinally {
   public void test() {
      for (int i = 0; i < 10; i++) {// 9 20
         try {
            System.out.println(i);// 11
         } finally {
            System.out.println("finally");// 13
            if (i == 5) {// 15
               break;
            }

            System.out.println("finally2");// 19
         }
      }

      System.out.println("after");// 23
   }// 24

   public void test1() {
      for (int i = 0; i < 10; i++) {// 27
         try {
            System.out.println(i);// 29
         } finally {
            System.out.println("finally");// 31
            if (i != 5) {// 33
               if (i == 4) {// 36
                  System.out.println("break");// 37
                  break;// 38
               }

               System.out.println("finally2");// 41
            }

            System.out.println("continue");// 34
            continue;// 35
         }
      }

      System.out.println("after");// 45
   }// 46

   public void test2() {
      for (int i = 0; i < 10; i++) {// 49
         try {
            System.out.println(i);// 51
         } finally {
            System.out.println("finally");// 53
            if (i != 5) {// 55
               continue;
            }
            break;
         }
      }

      System.out.println("after");// 63
   }// 64

   public int test3(int x) {
      do {
