package pkg;

public class TestFinallyVarDef {
   public void test1() {
      int i;
      try {
         System.out.println("a");// 7
      } finally {
         i = 5;// 9
      }

      System.out.println(i);// 10 12
   }

   public void test2() {
      int i = 2;// 16

      try {
         System.out.println("a");// 18
      } finally {
         var5 = 5;// 20
