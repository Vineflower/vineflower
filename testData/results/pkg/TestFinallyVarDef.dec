   public void test3InCatch() {
      try {
         System.out.println("try");// 28
      } catch (Exception var6) {// 29
         Exception ex = var6;
         System.out.println(var6);// 30

         try {
            System.out.println(ex);// 32
         } finally {
            System.out.println(var6);// 34
         }

         System.out.println(var6);// 35 36
      }
   }// 38
}

