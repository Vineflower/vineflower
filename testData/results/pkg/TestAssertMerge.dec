package pkg;

public class TestAssertMerge {
   public void test(int i, int j) {
      while (true) {
         assert i > 0;// 6
         if (i < j) {// 7
            return;// 13
         }

         i++;// 11
      }
   }

   public void test1(int i, int j) {
      while (j > 10) {// 16
         assert i > 0;// 17
         if (i >= j) {// 18
            i++;// 22
            continue;
         }
         break;
      }
   }// 24

   public void test2(int i, int j) {
      assert i > 0;// 27

      while (j > 10 && i >= j) {// 29 30
         j++;// 34
      }
   }// 36
}

