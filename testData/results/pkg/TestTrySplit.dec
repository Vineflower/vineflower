package pkg;

public class TestTrySplit {
   public void test() {
      Object obj = null;// 5

      try {
         obj = new Object();// 7
         return;// 18
      } catch (ArithmeticException ex) {// 8
         if (obj != null) {// 9
            System.out.println("a");// 10
         }

         throwMyException(ex.getMessage());// 13
      } finally {
         System.out.println("b");// 16
      }
   }// 14

   public void testFlat() {
      Object obj = null;// 21

      label25: {
         try {
            try {
               obj = new Object();// 27
               break label25;
            } catch (ArithmeticException ex) {// 28
               if (obj != null) {// 29
                  System.out.println("a");// 30
               }
            }

            throwMyException(ex.getMessage());// 33
         } catch (Throwable t) {// 37
            System.out.println("b");// 38
            throw t;// 39
         }

         System.out.println("b");// 41
         return;// 42
      }

      System.out.println("b");// 44
   }// 45

   public static void throwMyException(String message) {
      throw new RuntimeException(message);// 48
   }
}

