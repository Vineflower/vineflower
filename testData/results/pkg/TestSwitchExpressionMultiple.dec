package pkg;

public class TestSwitchExpressionMultiple {
   public int test(int i1, int i2) {
      return switch (switch (i2) {// 7
         case 0 -> 1;// 8
         case 1 -> 0;// 9
         default -> 0;// 10
      }) {
         case 0 -> 1;// 12
         case 1 -> 0;// 13
         default -> 0;// 14
      } + switch (i1) {
         case 0 -> {
            switch (i2) {// 16
               case 0:
                  yield 1;// 17
               case 1:
                  yield 0;// 18
               default:
                  yield 0;// 19
            }
         }
         case 1 -> 0;// 21
         default -> 0;// 22
      };
   }
}

