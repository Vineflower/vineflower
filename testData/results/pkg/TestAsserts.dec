package pkg;

public class TestAsserts {
   public static int foo() {
      int i = 1;// 21
      assert i > 1;// 22
      assert i > 1 && i < 5;// 23
      return 1;// 24
   }

   public void test1(int x) {
      System.out.println("a");// 28
      assert x > 5;// 29
      if (x == 7) {// 30
         System.out.println("b");// 31
      }

      System.out.println("c");// 34
   }// 35

   public void test2(int x) {
      System.out.println("a");// 38
      if (x == 7) {// 39
         System.out.println("b");// 40
      }

      assert x > 5;// 42
      System.out.println("c");// 45
   }// 46

   public void test5(int x) {
      System.out.println("a");// 63
      if (x == 7) {// 64
         System.out.println("b");// 65
      }

      assert false;
      System.out.println("c");// 70
   }// 71

   public void test6(int x) {
      System.out.println("a");// 74
      if (x > 7) {// 75
         assert x > 10;// 76
         System.out.println("c");// 77
      }

      System.out.println("c");// 80
   }// 81

   public void test7(int x) {
      System.out.println("a");// 84
      if (x > 7) {// 85
         assert x > 10;// 86
      }

      System.out.println("c");// 89
   }// 90

   public class Inner {
      public void test4(int x) {
         System.out.println("a");// 57
         assert x > 10;// 58
      }// 59
   }

   public static class InnerStatic {
      public void test3(int x) {
         System.out.println("a");// 50
         assert x > 10;// 51
      }// 52
   }
}

