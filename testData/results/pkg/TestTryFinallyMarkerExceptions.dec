package pkg;

public class TestTryFinallyMarkerExceptions {
   public void test0() {
      try {
         System.out.println("Hello");// 8
      } finally {
         long l = 5L;// 10
      }
   }// 16

   public void test1() {
      try {
         System.out.println("Hello");// 20
      } finally {
         System.out.println("Finally");// 22
      }

      System.out.println("Bye");// 29
   }// 30

   public void test2(int i) {
      try {
         System.out.println("Hello");// 35
      } finally {
         System.out.println("Finally");// 37
         if (i > 0) {// 38
            System.out.println(i);// 39
            return;// 40
         }
      }

      System.out.println("Bye");// 52
   }// 53
}

