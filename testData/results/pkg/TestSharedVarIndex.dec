package pkg;

import java.util.List;

public class TestSharedVarIndex {
   public void StringArrayVsString() {
      String[] b = new String[0];// 8
      String bx = "lol";// 11
   }// 12

   public static int ObjectVsInt(Object object, int value) {
      Object alias = object;// 16
      alias.hashCode();// 17
      alias = 0;// 20
      return alias + value;// 21 22
   }

   public static void ObjectVsInt2(int value) {
      int alias = null;// 27
      alias = value;// 30
      switch (alias) {// 31
         case 1:
            return;// 33
      }
   }// 35

   public void lambda(List<Integer> l) {
      int i = 0;// 42
      System.out.println(i);// 43
      l.forEach(ix -> System.out.println(ix + 1));// 45
   }// 46
}

