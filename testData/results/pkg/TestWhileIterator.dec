package pkg;

import java.util.Iterator;
import java.util.List;
import java.util.Random;
import java.util.Set;

public class TestWhileIterator {
   public int testNested(List<Object> list, Set<Object> set) {
      Iterator<Object> it1 = list.iterator();// 10
      Iterator<Object> it2 = set.iterator();// 11
      int i = 0;// 12

      while (it1.hasNext() && it2.hasNext()) {// 14
         if (it1.next().equals(it2.next())) {// 15
            i++;// 16
         }
      }

      return i;// 20
   }

   public Iterator<?> testDoubleUse1(Iterable<?> iterable) {
      System.out.println(iterable);// 24
      Iterator<?> iterator = iterable.iterator();// 25

      while (iterator.hasNext()) {// 26
         Object next = iterator.next();// 27
         if (next != null) {// 28
            System.out.println(next);// 29
            break;// 30
         }
      }

      while (iterator.hasNext()) {// 33
         Object next = iterator.next();// 34
         if (next != null) {// 35
            System.out.println(next);// 36
         }
      }

      return iterator;// 39
   }

   public Iterator<?> testDoubleUse2(Iterable<?> iterable) {
      System.out.println(iterable);// 43
      Iterator<?> iterator = iterable.iterator();// 44

      while (iterator.hasNext()) {// 45
         Object next = iterator.next();// 46
         if (next != null) {// 47
            System.out.println(next);// 48
            break;// 49
         }
      }

      System.out.println(iterable);// 52

      while (iterator.hasNext()) {// 53
         Object next = iterator.next();// 54
         if (next != null) {// 55
            System.out.println(next);// 56
         }
      }

      return iterator;// 59
   }

   public Iterator<?> testDoubleUse3(Iterable<?> iterable) {
      System.out.println(iterable);// 63
      Iterator<?> iterator = iterable.iterator();// 64

      while (iterator.hasNext()) {// 65
         Object next = iterator.next();// 66
         if (next != null) {// 67
            System.out.println(next);// 68
            break;// 69
         }
      }

      if (iterator != null) {// 72
         while (iterator.hasNext()) {// 73
            Object next = iterator.next();// 74
            if (next != null) {// 75
               System.out.println(next);// 76
            }
         }
      }

      return iterator;// 80
   }

   public Iterator<?> testDoubleUse4(Iterable<?> iterable) {
      System.out.println(iterable);// 84
      Iterator<?> iterator = iterable.iterator();// 85

      while (iterator.hasNext()) {// 86
         Object next = iterator.next();// 87
         if (next != null) {// 88
            System.out.println(next);// 89
            break;// 90
         }
      }

      if (iterable != null) {// 93
         while (iterator.hasNext()) {// 94
            Object next = iterator.next();// 95
            if (next != null) {// 96
               System.out.println(next);// 97
            }
         }
      }

      return iterator;// 101
   }

   public Iterator<?> testDoubleUse5(Iterable<?> iterable) {
      System.out.println(iterable);// 105

      for (Object next : iterable) {// 106 108
         if (next != null) {// 109
            System.out.println(next);// 110
            break;// 111
         }
      }

      Iterator<?> var4 = iterable.iterator();// 114

      while (var4.hasNext()) {// 115
         Object next = var4.next();// 116
         if (next != null) {// 117
            System.out.println(next);// 118
         }
      }

      return var4;// 121
   }

   public void testDoubleUse6(Iterable<?> iterable) {
      System.out.println(iterable);// 125

      for (Object next : iterable) {// 126 128
         if (next != null) {// 129
            System.out.println(next);// 130
            break;// 131
         }
      }

      for (Object next : iterable) {// 134 136
         if (next != null) {// 137
            System.out.println(next);// 138
         }
      }
   }// 141

   public Iterator<?> testOtherUse1(Iterable<?> iterable) {
      System.out.println(iterable);// 144
      Iterator<?> iterator = iterable.iterator();// 145

      while (iterator.hasNext()) {// 146
         Object next = iterator.next();// 147
         if (next != null) {// 148
            System.out.println(next);// 149
            break;// 150
         }
      }

      return iterator;// 154
   }

   public Iterator<?> testOtherUse2(Iterable<?> iterable) {
      System.out.println(iterable);// 158

      for (Object next : iterable) {// 159 161
         if (next != null) {// 162
            System.out.println(next);// 163
            break;// 164
         }
      }

      return iterable.iterator();// 168
   }

   public void testOtherUse3(Iterable<?> iterable) {
      System.out.println(iterable);// 172
      Iterator<?> iterator = iterable.iterator();// 173

      while (iterator.hasNext()) {// 174
         Object next = iterator.next();// 175
         if (next != null) {// 176
            System.out.println(next);// 177
            break;// 178
         }
      }

      if (new Random().nextBoolean()) {// 182
         System.out.println(iterator);// 183
      }
   }// 185

   public void testOtherUse4(Iterable<?> iterable) {
      System.out.println(iterable);// 188

      for (Object next : iterable) {// 189 191
         if (next != null) {// 192
            System.out.println(next);// 193
            break;// 194
         }
      }

      if (new Random().nextBoolean()) {// 198
         System.out.println(iterable);// 199
      }
   }// 201
}

