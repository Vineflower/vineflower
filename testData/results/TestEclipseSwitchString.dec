package pkg;

public class TestEclipseSwitchString {
   public int test(String var1) {
      switch (var1) {// 5
         case "1":
            return 1;// 10
         case "2":
            return 2;// 12
      }

      System.out.println("Test");// 7
      return 0;// 15
   }

   public int test1(String var1) {
      switch (var1) {// 19
         case "1":
            return 1;// 24
         case "2":
         case "3":
            return 2;// 27
      }

      System.out.println("Test");// 21
      return 0;// 30
   }

   public int test2(String var1) {
      String var2 = var1;// 34
      switch (var1.hashCode()) {
         case 49:
            if (var2.equals("1")) {
               System.out.println("Hello");// 39
               return 2;// 42
            }
            break;
         case 50:
            if (var2.equals("2")) {
               return 2;
            }
            break;
         case 51:
            if (var2.equals("3")) {
               return 2;
            }
      }

      System.out.println("Test");// 36
      return 0;// 45
   }

   public int testHashcodeCollision(String var1) {
      switch (var1) {// 49
         case "BB":
            return 1;// 54
         case "Aa":
            return 2;// 56
         default:
            System.out.println("Test");// 51
            return 0;// 58
      }
   }

   public int testHashcodeCollision1(String var1) {
      switch (var1) {// 62
         case "BB":
         case "Aa":
            return 2;// 68
      }

      System.out.println("Test");// 64
      return 0;// 70
   }

   public int testHashcodeCollision2(String var1) {
      String var2 = var1;// 74
      switch (var1.hashCode()) {
         case 2112:
            label13: {
               if (!var2.equals("BB")) {
                  if (!var2.equals("Aa")) {
                     break label13;
                  }
               } else {
                  System.out.println("BB");// 79
               }

               return 2;// 81
            }
      }

      System.out.println("Test");// 76
      return 0;// 83
   }
}

