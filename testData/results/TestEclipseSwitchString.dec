package pkg;

public class TestEclipseSwitchString {
   public int test(String var1) {
      String var2 = var1;// 5
      switch (var1.hashCode()) {
         case 49:
            if (var2.equals("1")) {
               return 1;// 10
            }
            break;
         case 50:
            if (var2.equals("2")) {
               return 2;// 12
            }
      }

      System.out.println("Test");// 7
      return 0;// 8 15
   }

   public int test1(String var1) {
      String var2 = var1;// 19
      switch (var1.hashCode()) {
         case 49:
            if (var2.equals("1")) {
               return 1;// 24
            }
            break;
         case 50:
            if (var2.equals("2")) {
               return 2;// 27
            }
            break;
         case 51:
            if (var2.equals("3")) {
               return 2;
            }
      }

      System.out.println("Test");// 21
      return 0;// 22 30
   }

   public int test2(String var1) {
      String var2 = var1;// 34
      switch (var1.hashCode()) {
         case 49:
            if (var2.equals("1")) {
               System.out.println("Hello");// 39
               return 2;// 42
            }
            break;
         case 50:
            if (var2.equals("2")) {
               return 2;
            }
            break;
         case 51:
            if (var2.equals("3")) {
               return 2;
            }
      }

      System.out.println("Test");// 36
      return 0;// 37 45
   }

   public int testHashcodeCollision(String var1) {
      String var2 = var1;// 49
      switch (var1.hashCode()) {
         case 2112:
            if (var2.equals("BB")) {
               return 1;// 54
            } else if (var2.equals("Aa")) {
               return 2;// 56
            }
         default:
            System.out.println("Test");// 51
            return 0;// 52 58
      }
   }

   public int testHashcodeCollision1(String var1) {
      String var2 = var1;// 62
      switch (var1.hashCode()) {
         case 2112:
            if (var2.equals("BB") || var2.equals("Aa")) {
               return 2;// 68
            }
      }

      System.out.println("Test");// 64
      return 0;// 65 70
   }

   public int testHashcodeCollision2(String var1) {
      String var2 = var1;// 74
      switch (var1.hashCode()) {
         case 2112:
            label13: {
               if (!var2.equals("BB")) {
                  if (!var2.equals("Aa")) {
                     break label13;
                  }
               } else {
                  System.out.println("BB");// 79
               }

               return 2;// 81
            }
      }

      System.out.println("Test");// 76
      return 0;// 77 83
   }
}

