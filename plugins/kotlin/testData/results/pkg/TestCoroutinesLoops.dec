package pkg

import kotlin.coroutines.jvm.internal.Boxing

public class TestCoroutinesLoops {
   public suspend fun testA(a: Int): Int {
      return Boxing.boxInt(0)// 6
   }

   public suspend fun testTruthMachine(a: Int): Int {
      if (a != 0) {// 9
         while (true) {
            this.testA(a, null)// 15
         }
      }

      return Boxing.boxInt(0)// 11
   }

   public suspend fun testForLoop(a: Int, b: Int): Int {
      var i: Int = a// 19
      if (a <= b) {// 20
         while (true) {
            if ((this.testA(i, null) as java.lang.Number).intValue() == 17) {// 21
               return Boxing.boxInt(i)// 22
            }

            if (i == 17) {// 25
               this.testTruthMachine(a, null)// 26
            }

            if (i == b) {
               break
            }

            i++
         }
      }

      return Boxing.boxInt(0)// 30
   }

   public suspend fun testForLoopWithBreak(a: Int, b: Int): Int {
      var i: Int = a// 33
      if (a <= b) {// 34
         while ((this.testA(i, null) as java.lang.Number).intValue() != 17) {// 35
            if (i == 17) {// 39
               this.testTruthMachine(a, null)// 40
            }

            if (i == b) {
               break
            }

            i++
         }
      }

      return Boxing.boxInt(0)// 44
   }

   public suspend fun testForLoopWithContinue(a: Int, b: Int): Int {
      var i: Int = a// 47
      if (a <= b) {// 48
         while (true) {
            if ((this.testA(i, null) as java.lang.Number).intValue() != 17 && i == 17) {// 49 53
               this.testTruthMachine(a, null)// 54
            }

            if (i == b) {
               break
            }

            i++
         }
      }

      return Boxing.boxInt(0)// 58
   }

   public suspend fun testNestedForLoop(a: Int, b: Int): Int {
      var i: Int = a// 61
      if (a <= b) {
         while (true) {
            var j: Int = a// 63
            if (a <= b) {
               while (true) {
                  if ((this.testA(i * j, null) as java.lang.Number).intValue() == 17) {// 64
                     return Boxing.boxInt(i)// 65
                  }

                  if (i == 17 * j) {// 68
                     this.testTruthMachine(a + j, null)// 69
                  }

                  if ((this.testA(j, null) as java.lang.Number).intValue() == 17) {// 72
                     break
                  }

                  if (j == 17 - i) {// 76
                     this.testTruthMachine(a, null)// 77
                  }

                  if (j == b) {
                     break
                  }

                  j++
               }
            }

            if (i == b) {// 62
               break
            }

            i++
         }
      }

      return Boxing.boxInt(0)// 82
   }
}

