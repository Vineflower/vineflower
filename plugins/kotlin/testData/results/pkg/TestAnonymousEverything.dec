package pkg

import kotlin.jvm.functions.Function2
import kotlin.jvm.internal.Ref.IntRef
import kotlin.reflect.KFunction

public class TestAnonymousEverything {
   public fun testPlainLambda() {
      ({ x: Int, x: Int ->
         return x + y// 7
      }).invoke(1, 2)// 8
   }// 9

   public fun testSerializableLambda() {
      <unknownclass>.INSTANCE.invoke(1, 2)// 12 13
   }// 14

   public fun testAnonymousObject() {
      (object {
         public fun foo(x: Int, y: Int): Int {
            return x + y// 19
         }
      }).foo(1, 2)// 22
   }// 23

   public fun testFunctionAnonymousObject() {
      (object : (Int, Int) -> Int {
         public open operator fun invoke(x: Int, y: Int): Int {
            return x + y// 28
         }
      }).invoke(1, 2)// 31
   }// 32

   public fun testAnonymousFunction() {
      ({ x: Int, x: Int ->
         return x + y// 35
      }).invoke(1, 2)// 36
   }// 37

   public fun add(x: Int, y: Int): Int {
      return x + y// 39
   }

   public fun testFunctionReference() {
      (((new <undefinedtype>(this)) as KFunction) as Function2).invoke(1, 2)// 42 43
   }// 44

   public fun testMultipleSubtypes() {
      val obj: Any = new <undefinedtype>()// 47
      obj.run()// 52
      obj.accept(Unit.INSTANCE)// 53
   }// 54

   public fun testNestedLambdas() {
      ({ x: Int ->
         return (({ y: Int ->
            return `$x` + y// 58
         }).invoke(1) as java.lang.Number).intValue()// 59
      }).invoke(1)// 61
   }// 62

   public fun testCapturedLocalVariables() {
      val x: IntRef = new IntRef()// 65
      x.element = 1
      ({ 
         return `$x`.element++// 66
      }).invoke()// 67
      ({ 
         return `$y`// 70
      }).invoke()// 71
   }// 72
}

