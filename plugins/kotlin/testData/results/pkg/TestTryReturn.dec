            }

            val var10000: Any = supplier.get()
            return var10000 as java.lang.Boolean// 58
         }

         var5 = c && supplier.get() as java.lang.Boolean
      } finally {
         System.out.println("Finally")
      }

      return var5// 51 60
   }

