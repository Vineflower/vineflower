package pkg

import java.util.Dictionary
import kotlin.coroutines.jvm.internal.Boxing

public class TestSimpleCoroutines {
   public suspend fun testA(a: Int): Int {
      return Boxing.boxInt(0)// 8
   }

   public suspend fun testSingleWait(a: Int): Int {
      return Boxing.boxInt(a + (this.testA(a, null) as java.lang.Number).intValue())// 11 12
   }

   public suspend fun testSingleWaitAtTail(a: Int): Int {
      return this.testA(a + 5, `$completion`)// 16
   }

   public suspend fun testDoubleWait(a: Int): Int {
      return Boxing.boxInt(a + (this.testA(a, null) as java.lang.Number).intValue() + (this.testSingleWait(a + 1, null) as java.lang.Number).intValue())// 19 20
   }

   public suspend fun testWithWaitAtEnd(a: Int): Int {
      return this.testSingleWaitAtTail(// 23 24
         (this.testA(a, null) as java.lang.Number).intValue() + (this.testSingleWait(a + 1, null) as java.lang.Number).intValue(), null
      )
   }

   public suspend fun testConditionalWait(a: Int): Int {
      return if (a > 0) Boxing.boxInt(a + (this.testA(a, null) as java.lang.Number).intValue()) else Boxing.boxInt(a)// 27 29 32
   }

   public suspend fun testConditionalWaitPhi(a: Int): Int {
      val var9: Int
      if (a > 0) {// 36 37
         var9 = a + (this.testA(a, null) as java.lang.Number).intValue()// 38
      } else {
         var9 = a + 3// 40
      }

      return Boxing.boxInt(var9)// 43
   }

   public suspend fun testConditionalWaitAtTail(a: Int): Int {
      return if (a > 0) this.testA(a + 5, `$completion`) else Boxing.boxInt(a)// 47 48 51
   }

   public suspend fun testMultipleConditionalWait(a: Int): Int {
      label29@       if (a > 0) {// 54
         return Boxing.boxInt(a + (this.testA(a, null) as java.lang.Number).intValue())// 56
      } else {
         return if (a < 10) Boxing.boxInt(a + (this.testA(a + 9, null) as java.lang.Number).intValue()) else Boxing.boxInt(a)// 59 60 63
      }
   }

   public suspend fun testSuspendInCondition(a: Int): Boolean {
      if ((this.testA(a, null) as java.lang.Number).intValue() == 0) {// 66 67
         System.out.println("testA is 0")// 68
         return Boxing.boxBoolean(true)// 69
      } else {
         return Boxing.boxBoolean(false)// 72
      }
   }

   public suspend fun testSuspendedBooleanInCondition(a: Int): Boolean {
      if (this.testSuspendInCondition(a, null) as java.lang.Boolean) {// 75 76
         System.out.println("testSuspendInCondition is true")// 77
         return Boxing.boxBoolean(true)// 78
      } else {
         return Boxing.boxBoolean(false)// 81
      }
   }

   public suspend fun testReturnNullability(a: Int): Dictionary<String?, Dictionary<List<Int?>, List<Int>>?> {
      throw new NotImplementedError(null, 1, null)// 85
   }
}

